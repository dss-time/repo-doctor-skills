{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Golden workflow fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "workflow_id",
    "prompts",
    "expected"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "workflow_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "prompts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "en",
        "zh-CN"
      ],
      "properties": {
        "en": {
          "type": "string",
          "minLength": 1
        },
        "zh-CN": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ordered_skills",
        "required_gates",
        "terminal_skill",
        "forbidden_skips",
        "contract_assertions"
      ],
      "properties": {
        "ordered_skills": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "required_gates": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "terminal_skill": {
          "type": "string"
        },
        "forbidden_skips": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "contract_assertions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
          }
        }
      }
    }
  }
}
