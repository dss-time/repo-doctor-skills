{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/repo-doctor/workflow.schema.json",
  "title": "Repo Doctor Workflow Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "registry_id",
    "supported_platforms",
    "workflows"
  ],
  "properties": {
    "version": {
      "type": "integer"
    },
    "registry_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "supported_platforms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "codex",
          "claude-code",
          "cursor",
          "qwen",
          "kimi",
          "generic",
          "chatgpt-skill"
        ]
      }
    },
    "workflows": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "entry_conditions",
          "entry_stage",
          "supported_platforms",
          "stages",
          "forbidden_transitions",
          "stop_conditions"
        ],
        "properties": {
          "title": {
            "type": "object",
            "additionalProperties": false,
            "required": ["en", "zh-CN"],
            "properties": {
              "en": {"type": "string", "minLength": 1},
              "zh-CN": {"type": "string", "minLength": 1}
            }
          },
          "entry_conditions": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          },
          "entry_stage": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "supported_platforms": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string"}
          },
          "stages": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "id",
                "type",
                "skill",
                "optional",
                "condition",
                "prerequisites",
                "next",
                "alternatives",
                "permission",
                "approval_gate",
                "stop_conditions"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
                },
                "type": {
                  "type": "string",
                  "enum": ["skill", "gate"]
                },
                "skill": {"type": "string", "minLength": 1},
                "optional": {"type": "boolean"},
                "condition": {"type": "string", "minLength": 1},
                "prerequisites": {
                  "type": "array",
                  "uniqueItems": true,
                  "items": {"type": "string"}
                },
                "next": {
                  "type": "array",
                  "uniqueItems": true,
                  "items": {"type": "string"}
                },
                "alternatives": {
                  "type": "array",
                  "uniqueItems": true,
                  "items": {"type": "string"}
                },
                "permission": {
                  "type": "string",
                  "enum": ["none", "read_only", "write_scoped"]
                },
                "approval_gate": {"type": "string", "minLength": 1},
                "stop_conditions": {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": {"type": "string", "minLength": 1}
                }
              }
            }
          },
          "forbidden_transitions": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*->[a-z0-9]+(?:-[a-z0-9]+)*$"
            }
          },
          "stop_conditions": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    }
  }
}
